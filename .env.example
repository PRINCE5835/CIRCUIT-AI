# BreadBoard AI - Environment Variables
# Copy this file to .env and fill in your values
# For production: cp .env.example .env && edit values

# === General ===

APP_NAME=BreadBoard AI
APP_VERSION=0.1.0
ENVIRONMENT=development       # Set to "production" for deployment
DEBUG=false
LOG_LEVEL=INFO

# === Backend (FastAPI) ===

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Generate with: openssl rand -hex 32
BACKEND_SECRET_KEY=change-me-to-a-secure-random-value
BACKEND_CORS_ORIGINS=http://localhost:8080,http://localhost:5000
BACKEND_RATE_LIMIT=100/minute

# === Database ===
# For Docker (MySQL): mysql+aiomysql://breadboard:breadboard@mysql:3306/breadboard
# For Render (PostgreSQL): postgresql+asyncpg://user:pass@host:5432/breadboard
DATABASE_URL=postgresql+asyncpg://breadboard:breadboard@localhost:5432/breadboard

# MySQL specific (only needed when using MySQL)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=breadboard
MYSQL_PASSWORD=breadboard
MYSQL_DATABASE=breadboard
MYSQL_HOST=mysql
MYSQL_PORT=3306

# === AI Engine ===

AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8001

# Ollama
# For Docker: host = ollama, For local: host = localhost
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llava
OLLAMA_TIMEOUT=60

# === Speech ===

WHISPER_MODEL_SIZE=base
VOSK_MODEL_PATH=./engine/models/vosk/

# === Vision ===

YOLO_MODEL_PATH=./engine/models/yolo/
OCR_MODEL_PATH=./engine/models/ocr/

# === Security ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-secure-random-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Redis (optional) ===
# For Docker: host = redis, For local: host = localhost
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# === Marketplace (optional) ===

STRIPE_API_KEY=
PAYPAL_CLIENT_ID=

# === Monitoring ===

SENTRY_DSN=
PROMETHEUS_ENABLED=false
