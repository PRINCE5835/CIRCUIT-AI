# BreadBoard AI - Environment Variables

# === General ===

APP_NAME=BreadBoard AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# === Backend (FastAPI) ===

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_SECRET_KEY=breadboard_ai_backend_dev_secret_2026
BACKEND_CORS_ORIGINS=*
BACKEND_RATE_LIMIT=100/minute

# === Database (MySQL 8) ===

DATABASE_URL=mysql+aiomysql://breadboard:breadboard@localhost:3306/breadboard
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=breadboard
MYSQL_PASSWORD=breadboard
MYSQL_DATABASE=breadboard
MYSQL_HOST=localhost
MYSQL_PORT=3306

# === AI Engine ===

AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8001

# Ollama

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llava
OLLAMA_TIMEOUT=60

# === Speech ===

WHISPER_MODEL_SIZE=base
VOSK_MODEL_PATH=./engine/models/vosk/

# === Vision ===

YOLO_MODEL_PATH=./engine/models/yolo/
OCR_MODEL_PATH=./engine/models/ocr/

# === Security ===

JWT_SECRET_KEY=breadboard_ai_jwt_dev_secret_2026
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Redis (optional) ===

REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# === Marketplace (optional) ===

STRIPE_API_KEY=
PAYPAL_CLIENT_ID=

# === Monitoring ===

SENTRY_DSN=
PROMETHEUS_ENABLED=false
